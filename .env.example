# Copy this file to .env and adjust values for your environment.

# Canary root path
SERVER_PATH=C:/canary

# Database
MYSQL_DBNAME=canary
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=canary
MYSQL_PASS=canary

# Logging
ENV_LOG_LEVEL=debug
ENV_LOG_FILE=logs/login-server.txt

# Login-server endpoints
LOGIN_IP=127.0.0.1
LOGIN_HTTP_PORT=80
LOGIN_GRPC_PORT=9090
RATE_LIMITER_BURST=5
RATE_LIMITER_RATE=2

# Game server
SERVER_IP=127.0.0.1
SERVER_NAME=OTServBR-Global
SERVER_PORT=7172
SERVER_LOCATION=BRA
